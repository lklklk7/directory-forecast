# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/directory_forecast"

# Express session secret (generate a long random string)
SESSION_SECRET="change-me-to-a-long-random-secret"

# Twitch OAuth app credentials (from dev.twitch.tv/console)
TWITCH_CLIENT_ID="your-twitch-client-id"
TWITCH_CLIENT_SECRET="your-twitch-client-secret"
TWITCH_REDIRECT_URI="http://localhost:3000/auth/twitch/callback"

# Riot API key (from developer.riotgames.com)
RIOT_API_KEY="your-riot-api-key"

# Base URL of this backend
BASE_URL="http://localhost:3000"

# URL to redirect streamers to after successful account linking
FRONTEND_URL="http://localhost:3000"
